---
import '../styles/global.css';
import { sitePath } from '../utils/path';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pageTitle = title.includes('CNC-Technik') ? title : `${title} | CNC-Technik Reitz`;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={sitePath('/favicon.svg')} />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="logo" href={sitePath('/')} aria-label="Zur Startseite">
          <span class="logo-mark">DTR</span>
          <span>Datentechnik Reitz<small>CAD/CAM · CNC · Robotik</small></span>
        </a>
        <nav class="nav" aria-label="Hauptnavigation">
          <a href={sitePath('/ueber-uns')}>Über uns</a>
          <a href={sitePath('/ency')}>CAD/CAM</a>
          <a href={sitePath('/robotik')}>Robotik</a>
          <a href={sitePath('/p3d-slicer')}>P3D</a>
          <a href={sitePath('/schulung-support')}>Support</a>
          <a href={sitePath('/news')}>News</a>
          <a href={sitePath('/kontakt')}>Kontakt</a>
        </nav>
        <a class="button" href={sitePath('/kontakt')}>Beratung anfragen</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <h3>CAD/CAM Systeme Datentechnik Reitz GmbH & Co. KG</h3>
          <p>Effiziente CAD/CAM- und Robotiklösungen für CNC-Maschinen, Industrieroboter und moderne Fertigungsprozesse.</p>
          <p>Perfstraße 2 · 35216 Breidenstein</p>
        </div>
        <div>
          <h4>Navigation</h4>
          <div class="footer-links">
            <a href={sitePath('/ueber-uns')}>Über uns</a>
            <a href={sitePath('/ency')}>CAD/CAM Lösungen</a>
            <a href={sitePath('/robotik')}>Robotik</a>
            <a href={sitePath('/news')}>News</a>
          </div>
        </div>
        <div>
          <h4>Leistungen</h4>
          <div class="footer-links">
            <a href={sitePath('/p3d-slicer')}>P3D Slicer</a>
            <a href={sitePath('/postprozessoren')}>Postprozessoren</a>
            <a href={sitePath('/sonderentwicklung')}>Sonderentwicklung</a>
            <a href={sitePath('/schulung-support')}>Schulung & Support</a>
          </div>
        </div>
        <div>
          <h4>Kontakt</h4>
          <div class="footer-links">
            <a href="tel:+4964617593437">+49 (6461) 759 343 7</a>
            <a href="mailto:info@cnc-technik.de">info@cnc-technik.de</a>
            <a href={sitePath('/kontakt')}>Kontaktformular</a>
            <a href="https://dtr.zendesk.com/">Zendesk Support</a>
          </div>
        </div>
      </div>
    </footer>

    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script>
      window.addEventListener('load', () => {
        if (!window.netlifyIdentity) return;
        window.netlifyIdentity.init();
        const hash = window.location.hash || '';
        const isIdentityAction = hash.includes('confirmation_token') || hash.includes('invite_token') || hash.includes('recovery_token');
        if (isIdentityAction) {
          window.netlifyIdentity.open();
        }
        window.netlifyIdentity.on('login', () => {
          window.location.href = '/admin/';
        });
      });
    </script>
  </body>
</html>
